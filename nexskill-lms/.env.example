# Example environment variables for NexSkill LMS
# Copy this file to .env.local and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Storage Buckets (create these in Supabase Dashboard → Storage)
# Both buckets must be set to Public:
#   - course-thumbnails   → stores course thumbnail images
#   - course-previews     → stores course preview videos

# YouTube Data API v3 Key (for auto-fetching video durations)
# Get your free API key from: https://console.cloud.google.com/apis/credentials
# Optional: If not set, durations will be fetched when the first user watches the video
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
