# Example environment variables for NexSkill LMS
# Copy this file to .env.local and fill in your values

# Backend API URL (for video uploads)
VITE_API_URL=http://localhost:5000/api

# Cloudinary Configuration (for video thumbnails and delivery)
# Sign up at https://cloudinary.com and get your credentials
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# YouTube Data API v3 Key (for auto-fetching video durations)
# Get your free API key from: https://console.cloud.google.com/apis/credentials
# Free tier: 10,000 units/day (~2,500 video lookups)
# Optional: If not set, durations will be fetched when first user watches the video
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Note: Backend handles uploads via Multer + Cloudinary
# Frontend only needs cloud name for thumbnail/delivery URLs
